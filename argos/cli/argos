#!/usr/bin/env python3
"""argos — in-repo development launcher.

Resolves the repo root from this script's location, prepends it to sys.path
so ``argos.cli.__main__`` is importable without ``pip install``, and dispatches
through the unified CLI. Once the packaging-channel ADR lands and Argos is
installed via ``pip``/``pipx``, the entry point declared in ``pyproject.toml``
([project.scripts] argos = "argos.cli.__main__:main_entry") replaces this
shim.
"""

from __future__ import annotations

import os
import sys


def _repo_root() -> str:
    here = os.path.dirname(os.path.abspath(__file__))
    # argos/cli/argos -> argos/cli -> argos -> <repo root>
    return os.path.dirname(os.path.dirname(here))


def _main() -> int:
    root = _repo_root()
    if root not in sys.path:
        sys.path.insert(0, root)
    from argos.cli.__main__ import main
    return main(sys.argv[1:])


if __name__ == "__main__":
    sys.exit(_main())
